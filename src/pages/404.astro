---
import Base from "@/layouts/Base.astro";
import { t } from "@/i18n";
---

<Base title="404 — Not Found">
  <div class="container not-found">
    <div class="not-found__inner">
      <img src="/logo.svg" alt="" width="56" height="56" class="not-found__logo" />
      <h1 class="not-found__code">404</h1>
      <p class="not-found__msg">This haplogroup doesn't exist — or at least, not yet.</p>
      <div class="not-found__actions">
        <a href="/" class="btn btn--primary">{t("nav.home")}</a>
        <a href="/search" class="btn btn--outline">{t("home.browse_all")}</a>
      </div>
    </div>
  </div>
</Base>

<style>
  .not-found {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    text-align: center;
  }

  .not-found__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .not-found__logo {
    opacity: 0.4;
    margin-bottom: 0.5rem;
  }

  .not-found__code {
    font-family: var(--font-serif);
    font-size: 5rem;
    color: var(--color-text-faint);
    line-height: 1;
  }

  .not-found__msg {
    color: var(--color-text-muted);
    font-size: 1.1rem;
    margin: 0;
  }

  .not-found__actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }
</style>
