---
import { t } from "@/i18n";
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="site-footer__brand">
      <img src="/logo.svg" alt="" width="24" height="24" />
      <span class="site-footer__name">Clade</span>
      <span class="site-footer__tagline">— {t("site.tagline")}</span>
    </div>
    <div class="site-footer__meta">
      <span>
        {t("footer.content_license")}{" "}
        <a href="https://creativecommons.org/licenses/by-sa/4.0/" target="_blank" rel="noopener noreferrer">
          CC BY-SA 4.0
        </a>
      </span>
      <span>
        {t("footer.code_license")}{" "}
        <a href="https://www.gnu.org/licenses/agpl-3.0.html" target="_blank" rel="noopener noreferrer">
          GNU AGPL 3.0
        </a>
      </span>
      <span>
        <a href="https://github.com/AnmiTaliDev/clade" target="_blank" rel="noopener noreferrer">
          {t("footer.contribute")}
        </a>
      </span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    background: var(--color-bg-alt);
    margin-top: 4rem;
    padding: 1.5rem 0;
  }

  .site-footer__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .site-footer__brand {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.875rem;
  }

  .site-footer__name {
    font-family: var(--font-serif);
    font-weight: normal;
    color: var(--color-text);
  }

  .site-footer__tagline {
    color: var(--color-text-muted);
  }

  .site-footer__meta {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    flex-wrap: wrap;
  }

  .site-footer__meta a {
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .site-footer__inner { flex-direction: column; align-items: flex-start; }
  }
</style>
