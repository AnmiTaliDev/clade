---
import type { Haplogroup } from "@/types/haplogroup";
import { t } from "@/i18n";

interface Props {
  haplogroup: Haplogroup;
  compact?: boolean;
}

const { haplogroup: h, compact = false } = Astro.props;

const typeLabel = h.type === "Y-DNA"
  ? t("haplogroup.type_y")
  : h.type === "mtDNA"
  ? t("haplogroup.type_mt")
  : t("haplogroup.type_auto");

const badgeClass = h.type === "Y-DNA"
  ? "badge--ydna"
  : h.type === "mtDNA"
  ? "badge--mtdna"
  : "badge--auto";

const topDistribution = h.distribution
  .sort((a, b) => b.percentage - a.percentage)
  .slice(0, 3);
---

<article class={`haplogroup-card card${compact ? " haplogroup-card--compact" : ""}`}>
  <a href={`/haplogroup/${h.id}`} class="haplogroup-card__link" tabindex="-1" aria-hidden="true"></a>
  <header class="haplogroup-card__header">
    <div class="haplogroup-card__title-row">
      <h3 class="haplogroup-card__name">
        <a href={`/haplogroup/${h.id}`}>{h.name}</a>
      </h3>
      <span class={`badge ${badgeClass}`}>{typeLabel}</span>
    </div>
    <p class="haplogroup-card__origin">{h.origin.region} · {h.origin.period}</p>
  </header>

  {!compact && (
    <p class="haplogroup-card__desc">{h.description.slice(0, 180)}…</p>
  )}

  <div class="haplogroup-card__footer">
    <div class="haplogroup-card__dist">
      {topDistribution.map((d) => (
        <span class="haplogroup-card__dist-item">
          <span class="haplogroup-card__dist-name">{d.ethnicity}</span>
          <span class="haplogroup-card__dist-pct">{d.percentage}%</span>
        </span>
      ))}
    </div>
    {h.tags.slice(0, 3).map((tag) => (
      <span class="tag">{tag}</span>
    ))}
  </div>
</article>

<style>
  .haplogroup-card {
    position: relative;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: box-shadow 0.15s, border-color 0.15s;
  }

  .haplogroup-card:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-md);
  }

  .haplogroup-card__link {
    position: absolute;
    inset: 0;
    border-radius: var(--radius-lg);
  }

  .haplogroup-card__header {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .haplogroup-card__title-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .haplogroup-card__name {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    margin: 0;
  }

  .haplogroup-card__name a {
    color: var(--color-text);
    text-decoration: none;
    position: relative;
    z-index: 1;
  }

  .haplogroup-card__name a:hover {
    color: var(--color-accent);
  }

  .haplogroup-card__origin {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .haplogroup-card__desc {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0;
  }

  .haplogroup-card__footer {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: center;
    margin-top: auto;
  }

  .haplogroup-card__dist {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-right: auto;
  }

  .haplogroup-card__dist-item {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.78rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border-light);
    padding: 0.1em 0.5em;
    border-radius: var(--radius);
  }

  .haplogroup-card__dist-name {
    color: var(--color-text-muted);
  }

  .haplogroup-card__dist-pct {
    font-weight: 600;
    color: var(--color-accent);
  }

  .haplogroup-card--compact {
    padding: 0.9rem 1rem;
    gap: 0.5rem;
  }
</style>
